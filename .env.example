# ── IzdeMe environment ─────────────────────────────────────────────
# Copy this file to ".env" and fill in your values.

# Port the backend listens on
PORT=4173

# hh.ru API requires a descriptive User-Agent: "AppName/version (contact-email)"
# Register a real application at https://dev.hh.ru/admin to avoid throttling
# and get your server IP whitelisted past DDoS-Guard in production.
HH_USER_AGENT=IzdeMe-JobAgent/1.0 (murat.askarov@nu.edu.kz)

# Region / site. 40 = Kazakhstan → hh.kz
HH_AREA=40
HH_HOST=hh.kz

# Optional: OAuth2 access token from your registered hh.ru app.
# When set, requests are authenticated and far less likely to be throttled/blocked.
HH_ACCESS_TOKEN=

# AI models for resume parsing + tailoring (spec 2.2/2.3). The UI lets you switch
# between any providers that have a key set. Both have FREE tiers (no credit card).
# Set one or both; if neither is set the app falls back to local heuristics.
#
# Groq   — free key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
#
# Gemini — free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
#
# Which provider is selected by default (groq | gemini)
LLM_PROVIDER=groq
#
# (Advanced) point a provider at a custom OpenAI-compatible endpoint:
#   GROQ_BASE_URL=...   GEMINI_BASE_URL=...
# Legacy: LLM_API_KEY is still accepted as the Groq key.
