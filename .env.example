# ── IzdeMe environment ─────────────────────────────────────────────
# Copy this file to ".env" and fill in your values.

# Port the backend listens on
PORT=4173

# hh.ru API requires a descriptive User-Agent: "AppName/version (contact-email)"
# Register a real application at https://dev.hh.ru/admin to avoid throttling
# and get your server IP whitelisted past DDoS-Guard in production.
HH_USER_AGENT=IzdeMe-JobAgent/1.0 (murat.askarov@nu.edu.kz)

# Region / site. 40 = Kazakhstan → hh.kz
HH_AREA=40
HH_HOST=hh.kz

# Optional: OAuth2 access token from your registered hh.ru app.
# When set, requests are authenticated and far less likely to be throttled/blocked.
HH_ACCESS_TOKEN=

# LLM for AI resume parsing + tailoring (spec 2.2/2.3). Any OpenAI-COMPATIBLE API.
# Default provider is Groq, which has a FREE tier (no credit card):
#   1. Get a free key at https://console.groq.com/keys
#   2. Put it in LLM_API_KEY below
# When empty, the app transparently falls back to local heuristics (still works).
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Other free/compatible providers — just swap these three:
#   OpenAI : LLM_BASE_URL=https://api.openai.com/v1                         LLM_MODEL=gpt-4o-mini
#   Gemini : LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai  LLM_MODEL=gemini-2.0-flash  (free key: https://aistudio.google.com/apikey)
